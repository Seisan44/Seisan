{
  "explications": [
    {
      "nom": "Catégorie",
      "description": "Toute arme appartient à l’une de ces catégories : arme courante ou arme de guerre. Les maîtrises d’armes sont généralement liées à l’une de ces catégories."
    },
    {
      "nom": "Corps à corps ou à distance",
      "description": "Une arme de corps à corps sert à attaquer une cible située à 1,50 m ou moins de soi, tandis qu’une arme à distance permet d’attaquer une cible plus éloignée."
    },
    {
      "nom": "Dégâts",
      "description": "Indique les dégâts infligés par une attaque réussie ainsi que leur type."
    },
    {
      "nom": "Propriétés",
      "description": "Liste les propriétés spéciales de l’arme définies dans les règles."
    },
    {
      "nom": "Botte d’arme",
      "description": "Chaque arme possède une propriété botte. Son utilisation nécessite une capacité qui permet de l’exploiter."
    },
    {
      "nom": "Maîtrise des armes",
      "description": "Tout personnage peut manier une arme, mais il doit en avoir la maîtrise pour ajouter son bonus de maîtrise à ses jets d’attaque. Les personnages et les monstres disposent des maîtrises indiquées par leurs capacités ou leur profil."
    }
  ],
  "proprietes": [
    {
      "nom": "Allonge",
      "description": "Ajoute 1,50 m à votre allonge lorsque vous attaquez avec cette arme, y compris pour les attaques d’Opportunité."
    },
    {
      "nom": "Chargement",
      "description": "Vous ne pouvez tirer qu’un seul projectile par action, action Bonus ou Réaction, quel que soit le nombre d’attaques dont vous disposez."
    },
    {
      "nom": "Deux mains",
      "description": "L’arme nécessite l’utilisation des deux mains pour attaquer."
    },
    {
      "nom": "Finesse",
      "description": "Vous choisissez d’utiliser votre modificateur de Force ou de Dextérité pour les jets d’attaque et de dégâts."
    },
    {
      "nom": "Lancer",
      "description": "L’arme peut être lancée pour effectuer une attaque à distance. Les armes de corps à corps utilisent le même modificateur que pour une attaque au corps à corps."
    },
    {
      "nom": "Légère",
      "description": "Après avoir attaqué avec une arme légère, vous pouvez effectuer une attaque supplémentaire avec une autre arme légère grâce à une action Bonus. Cette attaque n’ajoute pas le modificateur de caractéristique aux dégâts, sauf si celui-ci est négatif."
    },
    {
      "nom": "Lourde",
      "description": "Les attaques avec cette arme sont effectuées avec Désavantage si votre Force est inférieure à 13 (arme de corps à corps) ou si votre Dextérité est inférieure à 13 (arme à distance)."
    },
    {
      "nom": "Munitions",
      "description": "L’arme nécessite des munitions spécifiques. Une munition est consommée à chaque attaque. Après un combat, vous pouvez récupérer la moitié des munitions utilisées (arrondie à l’inférieur)."
    },
    {
      "nom": "Polyvalente",
      "description": "L’arme peut être utilisée à une ou deux mains. Les dégâts entre parenthèses s’appliquent lorsqu’elle est maniée à deux mains."
    },
    {
      "nom": "Portée",
      "description": "La portée indique une portée normale et une portée longue. Les attaques au-delà de la portée normale sont effectuées avec Désavantage, et il est impossible d’attaquer au-delà de la portée longue."
    },
    {
      "nom": "Coup double",
      "description": "Lors de l’attaque supplémentaire accordée par la propriété Légère, vous pouvez effectuer cette attaque dans le cadre de l’action Attaque au lieu d’utiliser une action Bonus. Une seule fois par tour."
    },
    {
      "nom": "Écorchure",
      "description": "Si l’attaque manque sa cible, celle-ci subit tout de même des dégâts égaux au modificateur de la caractéristique utilisée pour l’attaque."
    },
    {
      "nom": "Enchaînement",
      "description": "Après avoir touché une créature, vous pouvez effectuer une attaque supplémentaire contre une seconde créature située à 1,50 m de la première et à votre portée. Cette attaque n’ajoute pas le modificateur de caractéristique aux dégâts, sauf s’il est négatif. Une seule fois par tour."
    },
    {
      "nom": "Ouverture",
      "description": "Après avoir infligé des dégâts à une créature, vous bénéficiez d’un Avantage à votre prochain jet d’attaque contre elle avant la fin de votre tour suivant."
    },
    {
      "nom": "Poussée",
      "description": "Lorsque vous touchez une créature de taille G ou inférieure, vous pouvez la repousser jusqu’à 3 m en ligne droite."
    },
    {
      "nom": "Ralentissement",
      "description": "Après avoir infligé des dégâts, vous pouvez réduire la Vitesse de la cible de 3 m jusqu’au début de votre tour suivant. Les réductions ne sont pas cumulatives."
    },
    {
      "nom": "Renversement",
      "description": "La cible doit réussir un jet de sauvegarde de Constitution (DD = 8 + modificateur de caractéristique utilisé pour l’attaque + bonus de maîtrise) ou tomber À terre."
    },
    {
      "nom": "Sape",
      "description": "La cible subit un Désavantage à son prochain jet d’attaque avant le début de votre tour suivant."
    }
  ],
