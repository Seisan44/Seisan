{
  "explications": [
    {
      "nom": "Catégorie",
      "description": "Chaque type d’armure appartient à l’une des catégories suivantes : armure légère, intermédiaire, lourde ou bouclier. La catégorie détermine notamment le temps nécessaire pour l’enfiler ou la retirer."
    },
    {
      "nom": "Classe d’armure (CA)",
      "description": "Indique la formule ou la valeur de la Classe d’armure conférée lorsque l’armure est portée."
    },
    {
      "nom": "Force",
      "description": "Certaines armures exigent une valeur minimale de Force. Si cette condition n’est pas remplie, la Vitesse du porteur est réduite de 3 m."
    },
    {
      "nom": "Discrétion",
      "description": "Certaines armures imposent un Désavantage aux jets de Dextérité (Discrétion)."
    },
    {
      "nom": "Formation aux armures",
      "description": "Une créature doit être formée au port d’une armure ou d’un bouclier pour en tirer pleinement parti. Les classes et certaines capacités accordent cette formation."
    },
    {
      "nom": "Armures légères, intermédiaires ou lourdes",
      "description": "Porter une armure sans y être formé impose un Désavantage à tous les jets de d20 utilisant la Force ou la Dextérité et empêche de lancer des sorts."
    },
    {
      "nom": "Bouclier",
      "description": "Le bonus de Classe d’armure d’un bouclier ne s’applique que si son porteur est formé à son utilisation."
    },
    {
      "nom": "Une seule à la fois",
      "description": "Une créature ne peut porter qu’une seule armure à la fois, ainsi qu’un seul bouclier."
    }
  ],
